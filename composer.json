{
    "name": "bpotmalnik/lunar-paynow",
    "description": "PayNow payment driver for LunarPHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "lunarphp/core": "^1.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pao": "^1.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Bpotmalnik\\LunarPaynow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bpotmalnik\\LunarPaynow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bpotmalnik\\LunarPaynow\\PaynowServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lint": "pint",
        "test:lint": "pint --test",
        "test:types": "phpstan",
        "test:unit": "pest --testsuite=Unit",
        "test:feature": "pest --testsuite=Feature",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit",
            "@test:feature"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
